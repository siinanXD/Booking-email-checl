# Kopiere diese Datei nach .env und trage echte Werte ein.
# .env steht in .gitignore – niemals Secrets committen.

# --- OpenAI ---
OPENAI_API_KEY=

# --- Gemini (optional, Phase C — Workflow-Multimodal Sandbox) ---
GEMINI_API_KEY=
GEMINI_MODEL_EXTRACT=gemini-2.0-flash
# live = echtes Modell (kostet API-Guthaben); mock = Dev ohne OpenAI-Kosten
LLM_MODE=live

# --- MongoDB Atlas ---
MONGODB_URI=
MONGODB_DB_NAME=ai_email

# --- Langfuse (Observability, @observe + langfuse.openai) ---
# Siehe docs/LANGFUSE.md
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
# Optional für Deep-Links in der Admin-Konsole
LANGFUSE_PROJECT_ID=

# --- App / Laufzeit ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Kosten & Limits (optional, Defaults in config/settings.py) ---
OPENAI_MODEL_CLASSIFY=gpt-4o-mini
OPENAI_MODEL_EXTRACT=gpt-4o-mini
OPENAI_MODEL_DRAFT=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small
# Vektorsuche (Fallähnlichkeit). true = MongoDB Atlas $vectorSearch
# (Index embedding_vector_index). false = Ähnlichkeitssuche deaktiviert
# (übersprungen, KEINE lokale In-Memory-Suche – schützt RAM).
# Ist Atlas an, aber offline/Index fehlt: Suche wird übersprungen + Warnung im Log.
SIMILARITY_USE_ATLAS=false
# Geplant (Roadmap Phase 12): semantisches Chunking + Re-Ranking — siehe docs/ROADMAP.md
# CHUNK_MAX_TOKENS=512
# CHUNK_OVERLAP_TOKENS=64
# CHUNK_STRATEGY=semantic
# RERANK_ENABLED=true
# RERANK_PROVIDER=cross_encoder
# RERANK_CANDIDATE_MULTIPLIER=4
MAX_TOKENS_PER_MAIL=8000
# Billiges Gate vor classify/extract für unbekannte Absender-Domains
TRIAGE_LLM_ENABLED=true
OPENAI_MODEL_TRIAGE=gpt-4o-mini
TRIAGE_LLM_MAX_BODY_CHARS=2000

# --- Human Review (kein Auto-Versand) ---
HUMAN_REVIEW_REQUIRED=true

# --- Offline-Eval (tests/eval/) ---
# mock = CI-Verdrahtung; live = echtes OpenAI (nicht in CI)
EVAL_LLM_MODE=mock
EVAL_MIN_CASE_RATE=1.0

# --- Alerts (optional) ---
WEBHOOK_ALERT_URL=

# --- Microsoft Graph / Outlook (Ingestion) ---
# delegated = Device Code + /me (privat Hotmail/Outlook.com, Dev)
# oauth = Browser-Redirect pro Mandant (Onboarding „Mit Microsoft anmelden“)
# application = Client Credentials + /users/{OUTLOOK_MAILBOX}/... (Shared Mailbox)
OUTLOOK_AUTH_MODE=delegated
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Pflicht für oauth (Onboarding) und application; in Azure als Web-Redirect registrieren:
# OUTLOOK_OAUTH_REDIRECT_URI=http://localhost:5001/api/mail/outlook/callback
AZURE_CLIENT_SECRET=
# common | consumers | organizations | {tenant-id}
AZURE_AUTHORITY=common
OUTLOOK_MAILBOX=
# Max. Mails pro Lauf (neueste zuerst); Standard 100
OUTLOOK_FETCH_MAX=100
# Geplant (Roadmap Phase 7): Erst-Sync neuer Mandanten — nur ab Registrierung + N davor
# MAIL_INGEST_INITIAL_LOOKBACK=50
# MAIL_INGEST_INITIAL_FETCH_CAP=120
# true = nur ungelesene (weniger Duplikat-Polls; kann gelesene, noch nicht
# verarbeitete Mails übersehen — trotzdem max. OUTLOOK_FETCH_MAX)
OUTLOOK_FETCH_UNREAD_ONLY=false
# Hinweis: Sync liest nur INBOX (kein Junk/Spam-Ordner). Siehe docs/COST_TRIAGE.md
# Nach Ingestion: none (Default, Mail.Read) | mark_read | move (ReadWrite noetig)
OUTLOOK_POST_ACTION=none
# Bei OUTLOOK_POST_ACTION=move: Anzeigename des Zielordners
# OUTLOOK_PROCESSED_FOLDER=Processed
# OUTLOOK_TOKEN_CACHE_PATH=.outlook_token_cache.json
# Test delegated: .\scripts\test_graph_mailbox_delegated.ps1
# Ingest: py -3.11 scripts/run_outlook_ingest.py

# --- LangGraph Checkpoint (optional, Produktion) ---
LANGGRAPH_CHECKPOINT_URI=

# --- Web / Auth (Flask + React Dashboard) ---
# Pflicht in Produktion: openssl rand -hex 32
FLASK_SECRET_KEY=
ADMIN_EMAIL=admin@example.com
# Starkes Passwort; leer = Admin-Seed wird übersprungen (scripts/seed_admin.py)
ADMIN_PASSWORD=
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800
CORS_ORIGINS=http://localhost:5173
# Optional: explizite Frontend-URL für OAuth-Rückleitung (sonst erster CORS_ORIGINS-Eintrag)
# FRONTEND_URL=http://localhost:5180
FLASK_ENV=development
FLASK_PORT=5000
FRONTEND_BUILD_DIR=frontend/dist
WEB_DEMO_DATA=false
# Dev: weglassen oder leer = true bei APP_ENV=development (schnellerer Start)
# Prod: false — LangGraph-Checkpoints in MongoDB
# WEB_USE_MEMORY_CHECKPOINTER=false

# --- WhatsApp (optional, nach Human-Review-Freigabe, Meta Cloud API) ---
# Standard: deaktiviert – kein Versand bis Access Token + genehmigte Templates konfiguriert sind.
WHATSAPP_ENABLED=false
WHATSAPP_ACCESS_TOKEN=
# Numerische ID aus Meta (WhatsApp → API Setup → Phone number ID) – KEINE Rufnummer!
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0
WHATSAPP_TEMPLATE_LANGUAGE=de
WHATSAPP_TEMPLATE_CLEANING_TASK=booking_cleaning_task_de
WHATSAPP_TEMPLATE_STATUS_NOTICE=booking_status_notice_de
WHATSAPP_TEMPLATE_GUEST_INQUIRY=booking_guest_inquiry_de
# Geplant (Roadmap Phase 6): Admin-Alert bei neuem Support-Ticket — siehe docs/ROADMAP.md
# WHATSAPP_TEMPLATE_SUPPORT_TICKET=platform_support_ticket_de
# PLATFORM_ADMIN_WHATSAPP_E164=+491701234567
# Kommagetrennte E.164-Nummern, z. B. +491701234567,+491709876543
WHATSAPP_DEFAULT_RECIPIENTS=
# Optional: Zielnummer für scripts/test_whatsapp.py (hello_world-Verbindungstest)
WHATSAPP_TEST_RECIPIENT=
# Sofort WhatsApp bei Erkennung (ohne Review) — Standard: false
WHATSAPP_AUTO_ON_DETECT=false

# Account-ID für CLI-Ingestion – UUID des Mandanten (Postfach aus mail_connections)
# Wenn gesetzt, nutzt run_outlook_ingest.py die in der DB gespeicherte Verbindung (Outlook/IMAP).
INGEST_ACCOUNT_ID=

# Automatisches Mail-Polling (Worker scripts/run_mail_poll_loop.py)
MAIL_POLL_INTERVAL_SECONDS=300
# true = nur ein Lauf, dann Exit (Cron/Manual)
MAIL_POLL_RUN_ONCE=false

# --- Production (Docker / Gunicorn, optional) ---
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
