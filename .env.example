# Kopiere diese Datei nach .env und trage echte Werte ein.
# .env steht in .gitignore – niemals Secrets committen.

# --- OpenAI ---
OPENAI_API_KEY=
# live = echtes Modell (kostet API-Guthaben); mock = Dev ohne OpenAI-Kosten
LLM_MODE=live

# --- MongoDB Atlas ---
MONGODB_URI=
MONGODB_DB_NAME=ai_email

# --- Langfuse (Observability, @observe + langfuse.openai) ---
# Siehe docs/LANGFUSE.md
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# --- App / Laufzeit ---
APP_ENV=development
LOG_LEVEL=INFO

# --- Kosten & Limits (optional, Defaults in config/settings.py) ---
OPENAI_MODEL_CLASSIFY=gpt-4o-mini
OPENAI_MODEL_EXTRACT=gpt-4o-mini
OPENAI_MODEL_DRAFT=gpt-5-mini
EMBEDDING_MODEL=text-embedding-3-small
MAX_TOKENS_PER_MAIL=8000

# --- Human Review (kein Auto-Versand) ---
HUMAN_REVIEW_REQUIRED=true

# --- Offline-Eval (tests/eval/) ---
# mock = CI-Verdrahtung; live = echtes OpenAI (nicht in CI)
EVAL_LLM_MODE=mock
EVAL_MIN_CASE_RATE=1.0

# --- Alerts (optional) ---
WEBHOOK_ALERT_URL=

# --- Microsoft Graph / Outlook (Ingestion) ---
# delegated = Device Code + /me (privat Hotmail/Outlook.com, Dev)
# application = Client Credentials + /users/{OUTLOOK_MAILBOX}/... (Shared Mailbox)
OUTLOOK_AUTH_MODE=delegated
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
# Nur bei OUTLOOK_AUTH_MODE=application (oder optional für MSAL cache refresh)
AZURE_CLIENT_SECRET=
# common | consumers | organizations | {tenant-id}
AZURE_AUTHORITY=common
OUTLOOK_MAILBOX=
# Max. Mails pro Lauf (neueste zuerst); Standard 100
OUTLOOK_FETCH_MAX=100
# true = nur ungelesene (trotzdem max. OUTLOOK_FETCH_MAX)
OUTLOOK_FETCH_UNREAD_ONLY=false
# Nach Ingestion: none (Default, Mail.Read) | mark_read | move (ReadWrite noetig)
OUTLOOK_POST_ACTION=none
# Bei OUTLOOK_POST_ACTION=move: Anzeigename des Zielordners
# OUTLOOK_PROCESSED_FOLDER=Processed
# OUTLOOK_TOKEN_CACHE_PATH=.outlook_token_cache.json
# Test delegated: .\scripts\test_graph_mailbox_delegated.ps1
# Ingest: py -3.11 scripts/run_outlook_ingest.py

# --- LangGraph Checkpoint (optional, Produktion) ---
LANGGRAPH_CHECKPOINT_URI=

# --- Web / Auth (Flask + React Dashboard) ---
# Pflicht in Produktion: openssl rand -hex 32
FLASK_SECRET_KEY=
ADMIN_EMAIL=admin@example.com
# Starkes Passwort; leer = Admin-Seed wird übersprungen (scripts/seed_admin.py)
ADMIN_PASSWORD=
JWT_ACCESS_TOKEN_EXPIRES=3600
JWT_REFRESH_TOKEN_EXPIRES=604800
CORS_ORIGINS=http://localhost:5173
FLASK_ENV=development
FLASK_PORT=5000
FRONTEND_BUILD_DIR=frontend/dist
WEB_DEMO_DATA=false
WEB_USE_MEMORY_CHECKPOINTER=false

# --- Production (Docker / Gunicorn, optional) ---
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
