# =============================================================================
#  .env.example — Vollständige Konfiguration für Entwicklung & Produktion
#  Kopiere diese Datei nach .env und trage echte Werte ein.
#  .env steht in .gitignore — niemals Secrets committen!
#
#  Pflichtfelder (★) müssen gesetzt sein, sonst startet die App nicht.
#  Optionale Felder haben funktionierende Defaults.
# =============================================================================


# =============================================================================
#  KI / LLM
# =============================================================================

# ★ OpenAI API Key — https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Modelle (Defaults passen für Produktion, günstiger ist gpt-4o-mini)
OPENAI_MODEL_CLASSIFY=gpt-4o-mini
OPENAI_MODEL_EXTRACT=gpt-4o-mini
OPENAI_MODEL_DRAFT=gpt-4o-mini
OPENAI_MODEL_TRIAGE=gpt-4o-mini

# live = echtes Modell  |  mock = Dev ohne API-Kosten (deterministische Dummy-Antworten)
LLM_MODE=live

# Triage-Gate: billiges LLM-Vorfilter vor classify/extract (spart Kosten)
TRIAGE_LLM_ENABLED=true
TRIAGE_LLM_MAX_BODY_CHARS=2000

# Embedding-Modell für Ähnlichkeitssuche
# text-embedding-3-small = 1536 Dims, günstig
# text-embedding-3-large = 3072 Dims, besser (DIMENSIONS in setup_atlas_vector_index.py anpassen!)
EMBEDDING_MODEL=text-embedding-3-small

# Atlas $vectorSearch aktivieren (Index muss manuell erstellt werden):
#   python scripts/setup_atlas_vector_index.py
# false = Ähnlichkeitssuche deaktiviert (kein In-Memory-Fallback — schützt RAM)
SIMILARITY_USE_ATLAS=false

# Max. Token pro Mail-Body bevor Abschneiden (schützt Prompt-Länge & Kosten)
MAX_TOKENS_PER_MAIL=8000

# Gemini (optional — Phase C Multimodal-Sandbox für OCR-Workflows)
GEMINI_API_KEY=
GEMINI_MODEL_EXTRACT=gemini-2.0-flash


# =============================================================================
#  MongoDB Atlas
# =============================================================================

# ★ Verbindungs-URI — MongoDB Atlas: Cluster → Connect → Drivers
#   Format: mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true
#   Lokal (Docker): mongodb://localhost:27017
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true

# Datenbankname (Standard: ai_email)
MONGODB_DB_NAME=ai_email

# LangGraph Checkpoints in MongoDB (Produktion — Workflow-State überlebt Neustarts)
# Leer lassen = Wert von MONGODB_URI wird genutzt
# WEB_USE_MEMORY_CHECKPOINTER: leer = auto (true in development, false in production)
LANGGRAPH_CHECKPOINT_URI=
WEB_USE_MEMORY_CHECKPOINTER=


# =============================================================================
#  Observability — Langfuse (LLM-Tracing + Kosten)
# =============================================================================

# ★ Langfuse Keys — https://cloud.langfuse.com → Projekt → API Keys
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional: für Deep-Links in der Admin-Konsole
LANGFUSE_PROJECT_ID=


# =============================================================================
#  App / Laufzeit
# =============================================================================

# development | production | test
APP_ENV=development

# Log-Level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Kein automatischer Mailversand — jeder Entwurf muss manuell freigegeben werden
HUMAN_REVIEW_REQUIRED=true


# =============================================================================
#  Web / Auth (Flask + React Dashboard)
# =============================================================================

# ★ Flask Secret Key — Pflicht in Produktion!
#   Generieren: openssl rand -hex 32
FLASK_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32

# ★ Erster Admin-Account (wird beim ersten Start via seed_admin.py angelegt)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-secure-password

# JWT Token-Laufzeiten (Sekunden)
JWT_ACCESS_TOKEN_EXPIRES=3600       # 1 Stunde
JWT_REFRESH_TOKEN_EXPIRES=604800    # 7 Tage

# CORS-Origins für das Frontend (kommagetrennt)
# Entwicklung:
CORS_ORIGINS=http://localhost:5173
# Produktion (Beispiel):
# CORS_ORIGINS=https://yourdomain.com

# Frontend-URL für OAuth-Rückleitung (leer = erster Eintrag in CORS_ORIGINS)
FRONTEND_URL=

# Outlook OAuth Redirect-URI (muss in Azure App-Registrierung als Web-Redirect eingetragen sein)
# Entwicklung: http://localhost:5000/api/mail/outlook/callback
# Produktion:  https://yourdomain.com/api/mail/outlook/callback
OUTLOOK_OAUTH_REDIRECT_URI=

# development | production
FLASK_ENV=development
FLASK_PORT=5000

# Pfad zum gebauten React-Frontend (Produktion: docker-compose baut automatisch)
FRONTEND_BUILD_DIR=frontend/dist

# Demo-Daten beim Start anlegen (nur für Präsentationen)
WEB_DEMO_DATA=false


# =============================================================================
#  Microsoft Graph / Outlook (Mail-Ingestion)
# =============================================================================

# Auth-Modus:
#   delegated   = Device Code + /me  (privat: Hotmail/Outlook.com, Entwicklung)
#   oauth       = Browser-Redirect pro Mandant (Onboarding „Mit Microsoft anmelden")
#   application = Client Credentials + /users/{MAILBOX}/... (Shared Mailbox, Dienst-Konto)
OUTLOOK_AUTH_MODE=oauth

# Azure App-Registrierung — https://portal.azure.com → App registrations
# Pflicht für oauth und application
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=

# common | consumers | organizations | {tenant-id}
AZURE_AUTHORITY=common

# Shared Mailbox (nur für OUTLOOK_AUTH_MODE=application)
OUTLOOK_MAILBOX=

# Max. Mails pro Poll-Lauf (neueste zuerst, 1–1000)
OUTLOOK_FETCH_MAX=100

# Nur ungelesene Mails abrufen (weniger Duplikat-Checks, aber kann gelesene verpassen)
OUTLOOK_FETCH_UNREAD_ONLY=false

# Aktion nach erfolgreicher Ingestion:
#   none      = nichts tun (Mail.Read reicht)
#   mark_read = als gelesen markieren (Mail.ReadWrite nötig)
#   move      = in anderen Ordner verschieben (Mail.ReadWrite nötig)
OUTLOOK_POST_ACTION=none

# Zielordner bei OUTLOOK_POST_ACTION=move
# OUTLOOK_PROCESSED_FOLDER=Processed

# Pfad zum OAuth-Token-Cache (delegated-Modus)
OUTLOOK_TOKEN_CACHE_PATH=.outlook_token_cache.json

# Erst-Sync: wie viele alte Mails beim ersten Mandanten-Onboarding nachholen
MAIL_INGEST_INITIAL_LOOKBACK=50
MAIL_INGEST_INITIAL_FETCH_CAP=120

# Account-ID für direkten CLI-Ingest (UUID des Mandanten aus der DB)
# python scripts/run_outlook_ingest.py
INGEST_ACCOUNT_ID=


# =============================================================================
#  Mail-Polling (Hintergrund-Dienst)
# =============================================================================

# Poll-Interval in Sekunden (Minimum 30)
MAIL_POLL_INTERVAL_SECONDS=300

# true = nur ein Lauf, dann Exit (für Cron-Jobs)
MAIL_POLL_RUN_ONCE=false

# Parallele Accounts gleichzeitig pollen (1 = sequenziell, 4 = empfohlen ab 5+ Accounts)
# Thread-sicher: jeder Account hat eigene LangGraph thread_id + OAuth-Tokens
MAIL_POLL_MAX_WORKERS=1


# =============================================================================
#  WhatsApp Business API (Meta Cloud API, nach Human-Review-Freigabe)
# =============================================================================

# Aktivieren (false = kein Versand, auch wenn Token gesetzt)
WHATSAPP_ENABLED=false

# Meta Cloud API — https://developers.facebook.com/apps → WhatsApp → API Setup
WHATSAPP_ACCESS_TOKEN=
# Numerische Phone Number ID (NICHT die Rufnummer!)
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_API_VERSION=v21.0

# Template-Sprache und -Namen (müssen in Meta genehmigt sein)
WHATSAPP_TEMPLATE_LANGUAGE=de
WHATSAPP_TEMPLATE_CLEANING_TASK=booking_cleaning_task_de
WHATSAPP_TEMPLATE_STATUS_NOTICE=booking_status_notice_de
WHATSAPP_TEMPLATE_GUEST_INQUIRY=booking_guest_inquiry_de
WHATSAPP_TEMPLATE_SUPPORT_TICKET=platform_support_ticket_de

# Standard-Empfänger für Benachrichtigungen (kommagetrennte E.164-Nummern)
# Beispiel: +491701234567,+491709876543
WHATSAPP_DEFAULT_RECIPIENTS=

# Platform-Admin E.164-Nummer für Support-Ticket-Alerts
PLATFORM_ADMIN_WHATSAPP_E164=

# Sofortige WhatsApp-Nachricht bei Erkennung (ohne Review-Freigabe abwarten)
WHATSAPP_AUTO_ON_DETECT=false

# Test-Empfänger für scripts/test_whatsapp.py (hello_world Verbindungstest)
WHATSAPP_TEST_RECIPIENT=


# =============================================================================
#  Alerts (optional)
# =============================================================================

# Webhook-URL für LLM-Fehler-Alerts (z.B. Make/Zapier/n8n Webhook)
WEBHOOK_ALERT_URL=


# =============================================================================
#  Produktion — Docker / Gunicorn
# =============================================================================

# Gunicorn-Konfiguration (gunicorn.conf.py liest diese Werte)
# Empfehlung: WORKERS = 2 * CPU-Kerne + 1
# GUNICORN_BIND=0.0.0.0:8000
# GUNICORN_WORKERS=2
# GUNICORN_THREADS=4
# GUNICORN_TIMEOUT=120

# =============================================================================
#  Entwicklung / Offline-Eval
# =============================================================================

# Eval-Modus: mock = CI ohne API-Kosten  |  live = echtes OpenAI (kostet Geld!)
EVAL_LLM_MODE=mock
EVAL_MIN_CASE_RATE=1.0
